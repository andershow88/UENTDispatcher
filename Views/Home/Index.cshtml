@{
    ViewData["Title"] = "Glücksrad";
    var statuses = ViewBag.Statuses as List<UENTDispatcher.Services.EmployeeStatus> ?? new();
    var statusJson = System.Text.Json.JsonSerializer.Serialize(statuses);
    var sperreTage = ViewBag.SperreTage as int? ?? 21;
}

<div class="app-page-header">
    <div>
        <div class="app-page-title">🎯 Dispatcher der Woche auslosen</div>
        <div class="app-page-subtitle">
            Eine Person wird zufällig ausgewählt und übernimmt für die nächste Woche das Service Desk.
            Aktuelle Sperrfrist: <strong>@sperreTage Tage</strong>.
        </div>
    </div>
    <div>
        <a asp-controller="Dispatcher" asp-action="Log" class="btn-mc btn-mc-ghost">
            <i class="bi bi-clock-history"></i> Verlauf öffnen
        </a>
    </div>
</div>

<div class="wheel-stage">

    <!-- ────────────────── Wheel-Bereich (Mitte) ────────────────── -->
    <div class="wheel-frame">

        <div class="wheel-canvas-wrap">
            <div class="wheel-pointer"></div>
            <canvas id="wheelCanvas" class="wheel-canvas"></canvas>
            <div class="wheel-hub"><i class="bi bi-stars"></i></div>
        </div>

        <div class="wheel-actions">
            <button id="btnSpin" class="btn-mc btn-mc-primary btn-mc-lg">
                <i class="bi bi-arrow-repeat"></i> Drehen
            </button>
        </div>

        <div id="wheelError" class="wheel-error" style="display:none;"></div>

        <div id="toggleRow" class="toggle-row">
            <div>
                <div class="toggle-text-main"><i class="bi bi-shield-exclamation"></i> Sperrliste ignorieren</div>
                <div class="toggle-text-hint">
                    Aktiviert → auch gesperrte Personen drehen mit. Wird eine gesperrte Person bestätigt,
                    entsteht ein <strong>neuer Eintrag</strong> im Verlauf und die Sperre wird auf <strong>frische @sperreTage Tage</strong> gesetzt.
                </div>
            </div>
            <button type="button" id="toggleBlacklist" class="toggle-switch" aria-label="Sperrliste ignorieren"></button>
        </div>
    </div>

    <!-- ────────────────── Status-Panel (rechts) ────────────────── -->
    <div class="wheel-status-col">
        <div class="mc-card" style="margin-bottom: 1rem;">
            <div class="mc-card-header">
                <div class="mc-card-title"><i class="bi bi-people"></i> Teilnehmende</div>
                <div class="muted" style="font-size:.78rem;">Aktiv: <span id="totalActive">0</span></div>
            </div>
            <div class="mc-card-body">
                <div class="status-card-section green">
                    <div class="status-card-section-label">Verfügbar</div>
                    <div class="status-card-section-count" id="availableCount">0</div>
                </div>
                <div id="availableList" style="margin-bottom: .8rem;"></div>

                <div class="status-card-section amber">
                    <div class="status-card-section-label">Gesperrt</div>
                    <div class="status-card-section-count" id="lockedCount">0</div>
                </div>
                <div id="lockedList"></div>
            </div>
        </div>

    </div>

</div>

<!-- ────────────────── Winner-Modal: erscheint, sobald das Rad steht ────────────────── -->
<div class="modal-overlay" id="winnerModal">
    <div class="modal-card winner-card">
        <div class="modal-head winner-head">
            <div class="winner-emoji">🎉</div>
            <div>
                <div class="modal-title">Glückwunsch!</div>
                <div class="modal-subtitle">Diese Woche bist du dran</div>
            </div>
        </div>
        <div class="modal-body" style="text-align:center;">
            <div class="winner-name" id="winnerName">—</div>
            <div class="winner-witty" id="winnerWitty">—</div>
            <div id="winnerLockHint" class="winner-lock-hint" style="display:none;"></div>
            <div class="login-error" id="winnerError" style="display:none; margin-top:.8rem;"></div>
        </div>
        <div class="modal-footer" style="justify-content:center; gap:.8rem;">
            <button type="button" class="btn-mc btn-mc-ghost btn-mc-lg" id="winnerRespinBtn" onclick="onWinnerRespin()">
                <i class="bi bi-arrow-clockwise"></i> Erneut drehen
            </button>
            <button type="button" class="btn-mc btn-mc-gold btn-mc-lg" id="winnerConfirmBtn" onclick="onWinnerConfirm()">
                <i class="bi bi-check2-circle"></i> Bestätigen
            </button>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/wheel.js" asp-append-version="true"></script>
    <script>
        (function () {
            var initial = @Html.Raw(statusJson);
            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            UENTWheel.init(initial, token, @sperreTage);
        })();
    </script>
}
