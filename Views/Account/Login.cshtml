@{
    Layout = null;
    var returnUrl = ViewBag.ReturnUrl as string ?? "/";
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Anmelden – UENT Dispatcher</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/dispatcher.css" asp-append-version="true" />
    <script>
        (function () {
            try {
                var stored = localStorage.getItem('uent-theme');
                var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                document.documentElement.setAttribute('data-theme', theme);
            } catch (e) {}
        })();
    </script>
</head>
<body>

<div class="login-stage">
    <div class="login-card">
        <div class="login-logo login-logo-xl">
            <img src="~/images/merkur-logo.svg" alt="Merkur Privatbank" />
        </div>
        <div class="login-title">UENT Dispatcher Auslosung</div>

        <div class="login-error" id="loginError"></div>

        <!-- ── User-Modus (Default): nur Anmelden-Button ── -->
        <div id="userMode">
            <button type="button" class="btn-mc btn-mc-primary btn-mc-block btn-mc-lg" id="userLoginBtn" onclick="userLogin()">
                <i class="bi bi-box-arrow-in-right"></i> Anmelden
            </button>
        </div>

        <!-- ── Admin-Modus: klassische Anmeldung mit Username + Passwort ── -->
        <div id="adminMode" style="display:none;">
            <form id="loginForm" autocomplete="on">
                <div class="form-row">
                    <label class="form-label" for="benutzername">Admin-Benutzername</label>
                    <input type="text" id="benutzername" class="form-control" autocomplete="username" />
                </div>
                <div class="form-row">
                    <label class="form-label" for="passwort">Passwort</label>
                    <input type="password" id="passwort" class="form-control" autocomplete="current-password" />
                </div>
                <button type="submit" class="btn-mc btn-mc-primary btn-mc-block btn-mc-lg" id="adminLoginBtn">
                    <i class="bi bi-shield-lock"></i> Als Admin anmelden
                </button>
            </form>
        </div>
    </div>
</div>

<!-- ── Modus-Toggle unten rechts ── -->
<div class="login-mode-corner" id="modeCorner">
    <span class="login-mode-label-user">User-Zugriff</span>
    <button type="button" class="login-mode-toggle" id="modeToggle" onclick="toggleLoginMode()" aria-label="Anmeldemodus wechseln"></button>
    <span class="login-mode-label-admin">Admin-Zugriff</span>
</div>

<script>
    var loginMode = 'user';

    function toggleLoginMode() {
        loginMode = loginMode === 'user' ? 'admin' : 'user';
        var corner = document.getElementById('modeCorner');
        var toggle = document.getElementById('modeToggle');
        var userMode = document.getElementById('userMode');
        var adminMode = document.getElementById('adminMode');
        var err = document.getElementById('loginError');
        err.style.display = 'none';

        if (loginMode === 'admin') {
            corner.classList.add('admin');
            toggle.classList.add('admin');
            userMode.style.display = 'none';
            adminMode.style.display = 'block';
            setTimeout(function () {
                var b = document.getElementById('benutzername');
                if (b) b.focus();
            }, 60);
        } else {
            corner.classList.remove('admin');
            toggle.classList.remove('admin');
            userMode.style.display = 'block';
            adminMode.style.display = 'none';
        }
    }

    var RETURN_URL = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(returnUrl));

    async function userLogin() {
        var btn = document.getElementById('userLoginBtn');
        var err = document.getElementById('loginError');
        err.style.display = 'none';
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Anmelden …';
        try {
            var res = await fetch('/Account/UserLogin', { method: 'POST' });
            var data = await res.json();
            if (data.ok) {
                window.location.href = RETURN_URL;
            } else {
                err.textContent = data.error || 'Anmeldung fehlgeschlagen.';
                err.style.display = 'block';
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-box-arrow-in-right"></i> Anmelden';
            }
        } catch (e) {
            err.textContent = 'Verbindungsfehler: ' + e.message;
            err.style.display = 'block';
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-box-arrow-in-right"></i> Anmelden';
        }
    }

    // ── Logo-Regen: Merkur-Logos fallen rotierend ─────────────────────────
    // Praesentere Variante: groesser (bis 100 px), opaker (bis 0.5),
    // dichter (Spawn-Rate ~210 ms, DOM-Cap 80) und sofort beim Page-Load
    // bereits mit Logos im halben Fall, damit der Regen instantly da ist.
    function spawnLogoDrop(opts) {
        opts = opts || {};
        if (!opts.force && document.querySelectorAll('.logo-rain').length > 80) return;
        var img = document.createElement('img');
        img.src = '/images/merkur-logo.svg';
        img.alt = '';
        img.draggable = false;
        img.className = 'logo-rain';
        var size = 36 + Math.floor(Math.random() * 68);      // 36..104 px (war 22..60)
        var duration = 8 + Math.random() * 8;                 // 8..16 s
        var opacity = 0.18 + Math.random() * 0.32;            // 0.18..0.50 (war 0.07..0.25)
        var rot = 360 + Math.floor(Math.random() * 1440);     // 360..1800 deg (mehr Spin)
        var direction = Math.random() < 0.5 ? -1 : 1;
        img.style.left = (Math.random() * 100) + 'vw';
        img.style.width = size + 'px';
        img.style.opacity = opacity;
        img.style.animationDuration = duration + 's';
        img.style.setProperty('--rain-rot', (rot * direction) + 'deg');
        // Optional: Negativer Animations-Delay → Element startet mitten im Fall.
        // Wird beim initialen Schwung genutzt, damit der Schirm sofort gefuellt ist.
        if (opts.preStarted) {
            img.style.animationDelay = '-' + (Math.random() * duration * 0.85) + 's';
        }
        document.body.appendChild(img);
        setTimeout(function () { if (img.parentNode) img.remove(); }, duration * 1000 + 300);
    }
    // Sofortiger voller Regen — 35 Logos mit negativem Delay verteilen sich
    // ueber den gesamten Bildschirm beim Seiten-Load.
    for (var i = 0; i < 35; i++) {
        spawnLogoDrop({ preStarted: true, force: true });
    }
    // Konstanter dichter Nachschub
    setInterval(spawnLogoDrop, 210);

    document.getElementById('loginForm').addEventListener('submit', async function (e) {
        e.preventDefault();
        var err = document.getElementById('loginError');
        var btn = document.getElementById('adminLoginBtn');
        err.style.display = 'none';
        var benutzername = document.getElementById('benutzername').value.trim();
        var passwort = document.getElementById('passwort').value;
        if (!benutzername || !passwort) {
            err.textContent = 'Bitte Benutzername und Passwort eingeben.';
            err.style.display = 'block';
            return;
        }
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Anmelden …';
        try {
            var res = await fetch('/Account/Login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ benutzername: benutzername, passwort: passwort })
            });
            var data = await res.json();
            if (data.ok) {
                window.location.href = RETURN_URL;
            } else {
                err.textContent = data.error || 'Anmeldung fehlgeschlagen.';
                err.style.display = 'block';
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-shield-lock"></i> Als Admin anmelden';
            }
        } catch (e) {
            err.textContent = 'Verbindungsfehler: ' + e.message;
            err.style.display = 'block';
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-shield-lock"></i> Als Admin anmelden';
        }
    });
</script>

</body>
</html>
