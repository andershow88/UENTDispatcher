@model List<UENTDispatcher.Models.Employee>
@{
    ViewData["Title"] = "Mitarbeitende";
}

<div class="app-page-header">
    <div>
        <div class="app-page-title">👥 Mitarbeitende verwalten</div>
        <div class="app-page-subtitle">
            Wer am Glücksrad teilnehmen darf. Inaktive Personen sind aus dem Pool ausgeschlossen.
            Klick auf ein Foto, um es hochzuladen oder zu ersetzen.
        </div>
    </div>
    <div>
        <button type="button" class="btn-mc btn-mc-primary" onclick="openCreate()">
            <i class="bi bi-plus-lg"></i> Person hinzufügen
        </button>
    </div>
</div>

<div class="mc-card">
    <div class="mc-card-header">
        <div class="mc-card-title"><i class="bi bi-people"></i> Liste (@Model.Count)</div>
    </div>
    <div class="mc-card-body">
        <table class="emp-table">
            <thead>
                <tr>
                    <th style="width:88px;">Foto</th>
                    <th>Name</th>
                    <th style="width:170px;">Am Rad teilnehmen</th>
                    <th style="width:220px; text-align:right;">Aktionen</th>
                </tr>
            </thead>
            <tbody id="empBody">
                @if (Model.Count == 0)
                {
                    <tr><td colspan="4"><div class="empty-state"><i class="bi bi-person-plus"></i><div>Noch keine Mitarbeitenden angelegt.</div></div></td></tr>
                }
                else
                {
                    @foreach (var e in Model)
                    {
                        var initials = e.Vorname.Length > 0 ? e.Vorname.Substring(0, Math.Min(2, e.Vorname.Length)) : "?";
                        var hasPhoto = e.PhotoBytes != null && e.PhotoBytes.Length > 0;
                        // Cache-Bust per Foto-Bytelaenge: aendert sich das Foto, aendert sich
                        // die Laenge → andere URL → Browser laedt frisch (umgeht den 1h-Cache).
                        var photoVersion = hasPhoto ? e.PhotoBytes!.Length : 0;
                        <tr id="emp-row-@e.Id" data-id="@e.Id" data-vorname="@e.Vorname" data-aktiv="@(e.IstAktiv ? "1" : "0")">
                            <td>
                                <div class="emp-avatar" onclick="triggerPhotoUpload(@e.Id)" title="Foto hochladen / ersetzen">
                                    @if (hasPhoto)
                                    {
                                        <img id="emp-photo-@e.Id" src="/Employees/Photo/@e.Id?v=@photoVersion" alt="@e.Vorname" />
                                    }
                                    else
                                    {
                                        <span class="emp-avatar-initials" id="emp-photo-@e.Id">@initials.ToUpper()</span>
                                    }
                                    <div class="emp-avatar-overlay"><i class="bi bi-camera"></i></div>
                                </div>
                            </td>
                            <td class="emp-name-cell">
                                <span class="emp-name">@e.Vorname</span>
                            </td>
                            <td>
                                <button type="button"
                                        class="toggle-switch @(e.IstAktiv ? "on" : "")"
                                        id="emp-active-@e.Id"
                                        onclick="onToggleActive(@e.Id, this)"
                                        title="Am Glücksrad teilnehmen / nicht teilnehmen"></button>
                            </td>
                            <td class="emp-actions-cell">
                                <button type="button" class="btn-mc btn-mc-ghost emp-action-btn" onclick="openEdit(@e.Id)">
                                    <i class="bi bi-pencil"></i> Bearbeiten
                                </button>
                                <button type="button" class="btn-mc btn-mc-danger emp-action-btn" onclick="onDelete(@e.Id, '@e.Vorname')" title="Löschen">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Verstecktes File-Input fuer Foto-Upload aus der Liste -->
<input type="file" id="empPhotoFileInput" accept="image/jpeg,image/png,image/webp,image/gif" style="display:none;" />

<!-- ────────── Cropper-Modal: Bildausschnitt selber waehlen ────────── -->
<div class="modal-overlay" id="cropperModal">
    <div class="modal-card cropper-card">
        <div class="modal-head">
            <div class="icon-circle"><i class="bi bi-crop"></i></div>
            <div>
                <div class="modal-title">Bildausschnitt wählen</div>
                <div class="modal-subtitle">Verschieben + Zoom — der runde Bereich landet als Foto</div>
            </div>
        </div>
        <div class="modal-body">
            <div id="cropperStage" class="cropper-stage">
                <img id="cropperImg" class="cropper-img" alt="" draggable="false" />
                <svg class="cropper-mask" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
                    <defs>
                        <mask id="cropperHole">
                            <rect width="100" height="100" fill="white" />
                            <circle cx="50" cy="50" r="49.5" fill="black" />
                        </mask>
                    </defs>
                    <rect width="100" height="100" fill="rgba(0,0,0,.6)" mask="url(#cropperHole)" />
                    <circle cx="50" cy="50" r="49.5" fill="none" stroke="rgba(255,255,255,.9)" stroke-width=".4" />
                </svg>
            </div>
            <div class="cropper-controls">
                <button type="button" class="cropper-zoom-btn" onclick="cropperZoomBy(-25)" title="Auszoomen">−</button>
                <input type="range" id="cropperZoomSlider" class="cropper-zoom-slider" min="100" max="400" value="100" oninput="onCropperZoom()" />
                <button type="button" class="cropper-zoom-btn" onclick="cropperZoomBy(25)" title="Einzoomen">+</button>
            </div>
            <div style="text-align:center; font-size:.82rem; color:var(--mc-text-muted); margin-top:.6rem;">
                Foto verschieben → ziehen / wischen. Zoomen → Slider, Mausrad oder − / + Tasten.
            </div>
            <div class="login-error" id="cropperError" style="display:none; margin-top:.8rem;"></div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-mc btn-mc-ghost" onclick="closeCropper()">Abbrechen</button>
            <button type="button" class="btn-mc btn-mc-primary" id="cropperSaveBtn" onclick="saveCropped()">
                <i class="bi bi-check2"></i> Übernehmen
            </button>
        </div>
    </div>
</div>

<!-- ────────── Modal: Mitarbeiter löschen (im gleichen Stil wie Verlauf) ────────── -->
<div class="modal-overlay" id="empDeleteModal" onclick="if(event.target===this) closeEmpDeleteModal();">
    <div class="modal-card">
        <div class="modal-head danger">
            <div class="icon-circle"><i class="bi bi-trash"></i></div>
            <div>
                <div class="modal-title">Mitarbeiter:in löschen?</div>
                <div class="modal-subtitle">Auch alle Verlaufseinträge dieser Person werden entfernt.</div>
            </div>
        </div>
        <div class="modal-body">
            <div class="confirm-winner">
                <div class="confirm-winner-name" id="empDelName">—</div>
            </div>
            <p style="font-size:.86rem; color:var(--mc-text-muted); margin-bottom:0;">
                Diese Aktion kann nicht rückgängig gemacht werden. Alle bestätigten Auswahlen
                dieser Person werden ebenfalls aus dem Verlauf entfernt — laufende Sperrfristen
                fallen damit weg.
            </p>
            <div class="login-error" id="empDelError" style="display:none; margin-top:.8rem;"></div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-mc btn-mc-ghost" onclick="closeEmpDeleteModal()">Abbrechen</button>
            <button type="button" class="btn-mc btn-mc-danger" id="empDelConfirmBtn" onclick="performEmpDelete()">
                <i class="bi bi-trash"></i> Endgültig löschen
            </button>
        </div>
    </div>
</div>

<!-- Create/Edit Modal -->
<div class="modal-overlay" id="empModal" onclick="if(event.target===this) closeEmpModal();">
    <div class="modal-card">
        <div class="modal-head">
            <div class="icon-circle"><i class="bi bi-person-plus"></i></div>
            <div>
                <div class="modal-title" id="empModalTitle">Mitarbeiter:in</div>
                <div class="modal-subtitle">Vorname, Nachname und Status pflegen</div>
            </div>
        </div>
        <div class="modal-body">
            <div class="login-error" id="empError" style="display:none;"></div>
            <input type="hidden" id="empId" />

            <div class="form-row">
                <label class="form-label">Foto</label>
                <div class="emp-modal-photo">
                    <div class="emp-modal-avatar" id="empModalAvatar">
                        <img id="empModalAvatarImg" alt="" style="display:none;" />
                        <span class="emp-modal-avatar-initials" id="empModalAvatarInitials">?</span>
                    </div>
                    <div class="emp-modal-photo-actions">
                        <input type="file" id="empModalPhotoInput" accept="image/jpeg,image/png,image/webp,image/gif" style="display:none;" />
                        <button type="button" class="btn-mc btn-mc-ghost" onclick="document.getElementById('empModalPhotoInput').click()">
                            <i class="bi bi-camera"></i> Foto wählen
                        </button>
                        <button type="button" class="btn-mc btn-mc-danger" id="empModalPhotoRemoveBtn" style="display:none;" onclick="onModalPhotoRemove()" title="Foto entfernen">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
            </div>

            <div class="form-row">
                <label class="form-label" for="empVorname">Vorname</label>
                <input type="text" id="empVorname" class="form-control" />
            </div>
            <div class="toggle-row" id="empAktivRow">
                <div>
                    <div class="toggle-text-main">Aktiv (am Glücksrad teilnehmen)</div>
                    <div class="toggle-text-hint">Inaktive Personen sind aus dem Pool ausgeschlossen.</div>
                </div>
                <button type="button" id="empAktivSwitch" class="toggle-switch on" aria-label="Aktiv"></button>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-mc btn-mc-ghost" onclick="closeEmpModal()">Abbrechen</button>
            <button type="button" class="btn-mc btn-mc-primary" onclick="saveEmp()">
                <i class="bi bi-check2"></i> Speichern
            </button>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script>
    // ── Edit/Create Modal ───────────────────────────────────────────────
    var empAktivState = true;
    document.getElementById('empAktivSwitch').addEventListener('click', function () {
        empAktivState = !empAktivState;
        this.classList.toggle('on', empAktivState);
    });

    // ── Foto-State im Modal ─────────────────────────────────────────────
    // 'unchanged': bestehendes Foto bleibt (Edit-Default), 'remove': vorhandenes
    // Foto wird beim Speichern geloescht, 'upload': neuer Crop-Blob wird beim
    // Speichern hochgeladen.
    var modalPhotoState = 'unchanged';
    var modalPhotoBlob = null;

    function setModalAvatar(src, initials) {
        var img = document.getElementById('empModalAvatarImg');
        var initEl = document.getElementById('empModalAvatarInitials');
        var removeBtn = document.getElementById('empModalPhotoRemoveBtn');
        if (src) {
            img.src = src;
            img.style.display = 'block';
            initEl.style.display = 'none';
            removeBtn.style.display = '';
        } else {
            img.removeAttribute('src');
            img.style.display = 'none';
            initEl.textContent = initials || '?';
            initEl.style.display = '';
            removeBtn.style.display = 'none';
        }
    }

    function openCreate() {
        document.getElementById('empModalTitle').textContent = 'Neue Person hinzufügen';
        document.getElementById('empId').value = '';
        document.getElementById('empVorname').value = '';
        empAktivState = true;
        document.getElementById('empAktivSwitch').classList.add('on');
        document.getElementById('empError').style.display = 'none';
        modalPhotoState = 'unchanged';
        modalPhotoBlob = null;
        setModalAvatar(null, '?');
        document.getElementById('empModal').classList.add('open');
        setTimeout(() => document.getElementById('empVorname').focus(), 100);
    }

    function openEdit(id) {
        var row = document.getElementById('emp-row-' + id);
        document.getElementById('empModalTitle').textContent = 'Person bearbeiten';
        document.getElementById('empId').value = id;
        document.getElementById('empVorname').value = row.dataset.vorname;
        empAktivState = row.dataset.aktiv === '1';
        document.getElementById('empAktivSwitch').classList.toggle('on', empAktivState);
        document.getElementById('empError').style.display = 'none';
        modalPhotoState = 'unchanged';
        modalPhotoBlob = null;
        // Aktuelles Foto laden, falls vorhanden — sonst Initialen anzeigen
        var holder = document.getElementById('emp-photo-' + id);
        var hasPhoto = holder && holder.tagName === 'IMG';
        var initials = (row.dataset.vorname || '?').substring(0, 2).toUpperCase();
        if (hasPhoto) {
            setModalAvatar('/Employees/Photo/' + id + '?v=' + Date.now(), initials);
        } else {
            setModalAvatar(null, initials);
        }
        document.getElementById('empModal').classList.add('open');
        setTimeout(() => document.getElementById('empVorname').focus(), 100);
    }

    function closeEmpModal() {
        // Wenn der Cropper als "Kind-Modal" offen ist, immer mitschliessen —
        // sonst bliebe er ohne Bezug zur Person sichtbar. Reset-Reihenfolge:
        // erst Cropper-State weg, dann Modal-Sichtbarkeit, dann Photo-State.
        if (typeof window.closeCropper === 'function') window.closeCropper();
        document.getElementById('empModal').classList.remove('open');
        modalPhotoState = 'unchanged';
        modalPhotoBlob = null;
    }

    window.onModalPhotoRemove = function () {
        modalPhotoState = 'remove';
        modalPhotoBlob = null;
        var vorname = document.getElementById('empVorname').value.trim();
        var initials = (vorname || '?').substring(0, 2).toUpperCase();
        setModalAvatar(null, initials);
    };

    // File-Input im Modal → oeffnet Cropper im "pending" Modus
    document.getElementById('empModalPhotoInput').addEventListener('change', function (e) {
        if (!e.target.files || e.target.files.length === 0) return;
        var file = e.target.files[0];
        if (file.size > 5 * 1024 * 1024) {
            document.getElementById('empError').textContent = 'Foto zu groß (max. 5 MB).';
            document.getElementById('empError').style.display = 'block';
            e.target.value = '';
            return;
        }
        // Modus 'pending' → Cropper speichert Blob lokal, kein direkter Upload
        var empId = parseInt(document.getElementById('empId').value, 10) || 0;
        openCropper(file, empId, 'pending');
        e.target.value = '';
    });

    // Vom Cropper aufgerufen, wenn Mode = 'pending' und User hat "Übernehmen" geklickt.
    window.onCropperPendingResult = function (blob, dataUrl) {
        modalPhotoState = 'upload';
        modalPhotoBlob = blob;
        setModalAvatar(dataUrl, '?');
    };

    async function saveEmp() {
        var id = document.getElementById('empId').value;
        var vorname = document.getElementById('empVorname').value.trim();
        var err = document.getElementById('empError');
        if (!vorname) {
            err.textContent = 'Vorname ist Pflicht.';
            err.style.display = 'block';
            return;
        }
        try {
            var url = id ? '/Employees/Update' : '/Employees/Create';
            var body = id
                ? { id: parseInt(id, 10), vorname: vorname, istAktiv: empAktivState }
                : { vorname: vorname };
            var res = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            var data = await res.json();
            if (!data.ok) {
                err.textContent = data.error || 'Speichern fehlgeschlagen.';
                err.style.display = 'block';
                return;
            }
            var savedId = id ? parseInt(id, 10) : data.id;

            // Foto-Aenderungen erst NACH erfolgreichem Speichern anwenden
            if (modalPhotoState === 'upload' && modalPhotoBlob) {
                var fd = new FormData();
                fd.append('id', savedId);
                fd.append('file', modalPhotoBlob, 'photo.jpg');
                try { await fetch('/Employees/UploadPhoto', { method: 'POST', body: fd }); }
                catch (e) { /* Foto fehlgeschlagen, Person bleibt aber gespeichert */ }
            } else if (modalPhotoState === 'remove' && id) {
                try {
                    await fetch('/Employees/DeletePhoto', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id: savedId })
                    });
                } catch (e) { /* Trotzdem reload */ }
            }

            location.reload();
        } catch (e) {
            err.textContent = 'Verbindungsfehler: ' + e.message;
            err.style.display = 'block';
        }
    }

    // ── Aktiv-Toggle inline (in der Liste) ───────────────────────────────
    async function onToggleActive(id, btn) {
        var newState = !btn.classList.contains('on');
        btn.classList.toggle('on', newState);
        btn.disabled = true;
        try {
            var res = await fetch('/Employees/ToggleActive', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: id, istAktiv: newState })
            });
            var data = await res.json();
            if (!data.ok) {
                btn.classList.toggle('on', !newState); // revert
                alert(data.error || 'Änderung fehlgeschlagen.');
            } else {
                // Row-Daten aktualisieren, damit Edit-Modal den frischen Stand zeigt
                var row = document.getElementById('emp-row-' + id);
                if (row) row.dataset.aktiv = newState ? '1' : '0';
            }
        } catch (e) {
            btn.classList.toggle('on', !newState);
            alert('Verbindungsfehler: ' + e.message);
        } finally {
            btn.disabled = false;
        }
    }

    // ── Foto-Upload via Avatar-Klick ─────────────────────────────────────
    var pendingPhotoEmpId = null;

    function triggerPhotoUpload(id) {
        pendingPhotoEmpId = id;
        var input = document.getElementById('empPhotoFileInput');
        input.value = '';
        input.click();
    }

    document.getElementById('empPhotoFileInput').addEventListener('change', function (e) {
        var id = pendingPhotoEmpId;
        pendingPhotoEmpId = null;
        if (!id || !e.target.files || e.target.files.length === 0) return;
        var file = e.target.files[0];
        if (file.size > 5 * 1024 * 1024) {
            alert('Foto zu groß (max. 5 MB).');
            return;
        }
        // Statt direkt hochzuladen: Cropper-Modal oeffnen, damit der User
        // selbst den runden Ausschnitt waehlen kann.
        openCropper(file, id);
    });

    // ── Cropper: Pan + Zoom + Save als 400x400 JPEG ─────────────────────
    // mode='upload': direkter Upload an Server (Avatar-Klick in Liste)
    // mode='pending': Crop-Blob via window.onCropperPendingResult zurueck-
    //   geben, kein Upload — wird vom emp-Modal beim Speichern verarbeitet.
    var cropperState = {
        targetEmpId: null,
        mode: 'upload',
        dataUrl: null,
        naturalW: 0, naturalH: 0,
        tx: 0, ty: 0,
        scale: 1,
        minScale: 1,
        dragging: false,
        dragStartX: 0, dragStartY: 0,
        dragStartTx: 0, dragStartTy: 0
    };

    function getCropperStageSize() {
        return document.getElementById('cropperStage').clientWidth;
    }

    function openCropper(file, empId, mode) {
        cropperState.targetEmpId = empId;
        cropperState.mode = mode || 'upload';
        var reader = new FileReader();
        reader.onload = function (ev) {
            cropperState.dataUrl = ev.target.result;
            var probe = new Image();
            probe.onload = function () {
                cropperState.naturalW = probe.naturalWidth;
                cropperState.naturalH = probe.naturalHeight;
                document.getElementById('cropperImg').src = cropperState.dataUrl;
                document.getElementById('cropperError').style.display = 'none';
                document.getElementById('cropperModal').classList.add('open');
                // Layout muss erst settlen, dann initial fitten
                setTimeout(initCropper, 30);
            };
            probe.onerror = function () { alert('Bild konnte nicht gelesen werden.'); };
            probe.src = cropperState.dataUrl;
        };
        reader.readAsDataURL(file);
    }

    function initCropper() {
        var stage = getCropperStageSize();
        // Cover-Verhalten: Skalierung so, dass die kuerzere Seite die Stage fuellt
        var byW = stage / cropperState.naturalW;
        var byH = stage / cropperState.naturalH;
        cropperState.minScale = Math.max(byW, byH);
        cropperState.scale = cropperState.minScale;
        var dispW = cropperState.naturalW * cropperState.scale;
        var dispH = cropperState.naturalH * cropperState.scale;
        cropperState.tx = (stage - dispW) / 2;
        cropperState.ty = (stage - dispH) / 2;
        document.getElementById('cropperZoomSlider').value = 100;
        applyCropperTransform();
    }

    function applyCropperTransform() {
        var img = document.getElementById('cropperImg');
        var s = cropperState.scale;
        img.style.width = (cropperState.naturalW * s) + 'px';
        img.style.height = (cropperState.naturalH * s) + 'px';
        img.style.transform = 'translate(' + cropperState.tx + 'px, ' + cropperState.ty + 'px)';
    }

    function clampCropperPosition() {
        var stage = getCropperStageSize();
        var dispW = cropperState.naturalW * cropperState.scale;
        var dispH = cropperState.naturalH * cropperState.scale;
        var minTx = stage - dispW;
        var minTy = stage - dispH;
        cropperState.tx = Math.max(minTx, Math.min(0, cropperState.tx));
        cropperState.ty = Math.max(minTy, Math.min(0, cropperState.ty));
    }

    function onCropperZoom() {
        var slider = document.getElementById('cropperZoomSlider');
        var pct = parseFloat(slider.value) / 100;
        var stage = getCropperStageSize();
        var oldScale = cropperState.scale;
        var newScale = cropperState.minScale * pct;
        // Center fixiert lassen waehrend Zoom
        var imgX = (stage / 2 - cropperState.tx) / oldScale;
        var imgY = (stage / 2 - cropperState.ty) / oldScale;
        cropperState.scale = newScale;
        cropperState.tx = stage / 2 - imgX * newScale;
        cropperState.ty = stage / 2 - imgY * newScale;
        clampCropperPosition();
        applyCropperTransform();
    }

    window.cropperZoomBy = function (delta) {
        var slider = document.getElementById('cropperZoomSlider');
        var v = parseFloat(slider.value) + delta;
        v = Math.max(parseFloat(slider.min), Math.min(parseFloat(slider.max), v));
        slider.value = v;
        onCropperZoom();
    };

    function setupCropperDrag() {
        var stage = document.getElementById('cropperStage');
        if (stage.dataset.dragInit === '1') return;
        stage.dataset.dragInit = '1';

        var startDrag = function (clientX, clientY) {
            cropperState.dragging = true;
            cropperState.dragStartX = clientX;
            cropperState.dragStartY = clientY;
            cropperState.dragStartTx = cropperState.tx;
            cropperState.dragStartTy = cropperState.ty;
        };
        var moveDrag = function (clientX, clientY) {
            if (!cropperState.dragging) return;
            cropperState.tx = cropperState.dragStartTx + (clientX - cropperState.dragStartX);
            cropperState.ty = cropperState.dragStartTy + (clientY - cropperState.dragStartY);
            clampCropperPosition();
            applyCropperTransform();
        };
        var endDrag = function () { cropperState.dragging = false; };

        stage.addEventListener('mousedown', function (e) { startDrag(e.clientX, e.clientY); e.preventDefault(); });
        document.addEventListener('mousemove', function (e) { moveDrag(e.clientX, e.clientY); });
        document.addEventListener('mouseup', endDrag);

        stage.addEventListener('touchstart', function (e) {
            if (e.touches.length === 1) { startDrag(e.touches[0].clientX, e.touches[0].clientY); e.preventDefault(); }
        }, { passive: false });
        stage.addEventListener('touchmove', function (e) {
            if (e.touches.length === 1) { moveDrag(e.touches[0].clientX, e.touches[0].clientY); e.preventDefault(); }
        }, { passive: false });
        stage.addEventListener('touchend', endDrag);

        stage.addEventListener('wheel', function (e) {
            e.preventDefault();
            var delta = -e.deltaY * 0.05;
            cropperZoomBy(delta);
        }, { passive: false });
    }
    setupCropperDrag();

    window.closeCropper = function () {
        document.getElementById('cropperModal').classList.remove('open');
    };

    window.saveCropped = function () {
        var stage = getCropperStageSize();
        var output = 400;
        var canvas = document.createElement('canvas');
        canvas.width = output; canvas.height = output;
        var ctx = canvas.getContext('2d');
        var srcX = -cropperState.tx / cropperState.scale;
        var srcY = -cropperState.ty / cropperState.scale;
        var srcSize = stage / cropperState.scale;

        var img = new Image();
        img.onload = function () {
            ctx.drawImage(img, srcX, srcY, srcSize, srcSize, 0, 0, output, output);

            // Pending-Modus: Blob ans emp-Modal zurueckreichen, kein Upload
            if (cropperState.mode === 'pending') {
                canvas.toBlob(function (blob) {
                    if (!blob) {
                        document.getElementById('cropperError').textContent = 'Bild konnte nicht erzeugt werden.';
                        document.getElementById('cropperError').style.display = 'block';
                        return;
                    }
                    var dataUrl = canvas.toDataURL('image/jpeg', 0.92);
                    if (typeof window.onCropperPendingResult === 'function') {
                        window.onCropperPendingResult(blob, dataUrl);
                    }
                    closeCropper();
                }, 'image/jpeg', 0.92);
                return;
            }

            // Upload-Modus: direkter Server-Upload (Avatar-Klick in Liste)
            canvas.toBlob(async function (blob) {
                if (!blob) {
                    document.getElementById('cropperError').textContent = 'Bild konnte nicht erzeugt werden.';
                    document.getElementById('cropperError').style.display = 'block';
                    return;
                }
                var btn = document.getElementById('cropperSaveBtn');
                var err = document.getElementById('cropperError');
                err.style.display = 'none';
                btn.disabled = true;
                btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Lädt hoch…';
                try {
                    var fd = new FormData();
                    fd.append('id', cropperState.targetEmpId);
                    fd.append('file', blob, 'photo.jpg');
                    var res = await fetch('/Employees/UploadPhoto', { method: 'POST', body: fd });
                    var data = await res.json();
                    if (!data.ok) {
                        err.textContent = data.error || 'Upload fehlgeschlagen.';
                        err.style.display = 'block';
                        btn.disabled = false;
                        btn.innerHTML = '<i class="bi bi-check2"></i> Übernehmen';
                        return;
                    }
                    closeCropper();
                    var holder = document.getElementById('emp-photo-' + cropperState.targetEmpId);
                    if (holder && holder.tagName === 'IMG') {
                        holder.src = '/Employees/Photo/' + cropperState.targetEmpId + '?v=' + Date.now();
                        btn.disabled = false;
                        btn.innerHTML = '<i class="bi bi-check2"></i> Übernehmen';
                    } else {
                        location.reload();
                    }
                } catch (e) {
                    err.textContent = 'Verbindungsfehler: ' + e.message;
                    err.style.display = 'block';
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-check2"></i> Übernehmen';
                }
            }, 'image/jpeg', 0.92);
        };
        img.src = cropperState.dataUrl;
    };

    // ── Mitarbeiter loeschen (Modal) ─────────────────────────────────────
    var pendingEmpDeleteId = null;

    function onDelete(id, name) {
        pendingEmpDeleteId = id;
        document.getElementById('empDelName').textContent = name;
        document.getElementById('empDelError').style.display = 'none';
        document.getElementById('empDeleteModal').classList.add('open');
    }
    function closeEmpDeleteModal() {
        document.getElementById('empDeleteModal').classList.remove('open');
        pendingEmpDeleteId = null;
    }
    async function performEmpDelete() {
        if (!pendingEmpDeleteId) return;
        var btn = document.getElementById('empDelConfirmBtn');
        var err = document.getElementById('empDelError');
        err.style.display = 'none';
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Lösche…';
        try {
            var res = await fetch('/Employees/Delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: pendingEmpDeleteId })
            });
            var data = await res.json();
            if (!data.ok) {
                err.textContent = data.error || 'Löschen fehlgeschlagen.';
                err.style.display = 'block';
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-trash"></i> Endgültig löschen';
                return;
            }
            location.reload();
        } catch (e) {
            err.textContent = 'Verbindungsfehler: ' + e.message;
            err.style.display = 'block';
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-trash"></i> Endgültig löschen';
        }
    }

    document.addEventListener('keydown', function (e) {
        if (e.key !== 'Escape') return;
        // Gestaffeltes Schliessen: oberstes Modal zuerst. Cropper hat
        // hoechste z-index, also fang ihn als Erstes ab.
        var cropperOpen = document.getElementById('cropperModal').classList.contains('open');
        if (cropperOpen) {
            closeCropper();
            return;
        }
        var deleteOpen = document.getElementById('empDeleteModal').classList.contains('open');
        if (deleteOpen) {
            closeEmpDeleteModal();
            return;
        }
        var empOpen = document.getElementById('empModal').classList.contains('open');
        if (empOpen) closeEmpModal();
    });
</script>
}
